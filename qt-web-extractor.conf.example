# Configuration for qt-web-extractor
# Located at /etc/qt-web-extractor.conf
# Enable and start with: systemctl enable --now qt-web-extractor

# Listen address and port
HOST=127.0.0.1
PORT=8766

# Page load timeout in milliseconds
TIMEOUT_MS=30000

# Custom User-Agent (empty = default Chromium UA)
#USER_AGENT=

# UA auto-switch strategy:
# off      - never switch UA automatically
# on_block - when challenge/captcha is detected, switch through fallback UA pool
# rotate   - try primary UA then rotate through fallback UA pool every request
#UA_MODE=on_block

# Comma-separated fallback user-agent list.
# If empty, built-in mobile UA pool is used.
#UA_POOL=Mozilla/5.0\ (Linux;\ Android\ 14;\ Pixel\ 8)\ AppleWebKit/537.36\ (KHTML,\ like\ Gecko)\ Chrome/124.0.0.0\ Mobile\ Safari/537.36,Mozilla/5.0\ (iPhone;\ CPU\ iPhone\ OS\ 17_4\ like\ Mac\ OS\ X)\ AppleWebKit/605.1.15\ (KHTML,\ like\ Gecko)\ Version/17.4\ Mobile/15E148\ Safari/604.1

# API key for Bearer token auth (empty = no auth)
#API_KEY=

# Standard outbound proxy environment variables.
# Applies to both Chromium (Qt WebEngine) and HTTP fallback requests.
# Only HTTP/HTTPS forward proxies are supported end-to-end.
#HTTPS_PROXY=http://127.0.0.1:7890
#HTTP_PROXY=http://127.0.0.1:7890
#ALL_PROXY=http://127.0.0.1:7890
#NO_PROXY=127.0.0.1,localhost,.internal.example
